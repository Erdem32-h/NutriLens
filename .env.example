SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
RC_API_KEY_ANDROID=goog_your-revenuecat-android-key
RC_API_KEY_IOS=appl_your-revenuecat-ios-key
# Crash + error reporting. scripts/build_android_release.ps1 passes this as a
# --dart-define; main() skips Sentry init entirely when it is empty, so a
# release built without it reports nothing at all. This key was missing from
# the template, and therefore from .env, which is why every locally-built
# Android release shipped blind while Codemagic-built iOS reported normally.
SENTRY_DSN=https://your-key@oNNNNNN.ingest.de.sentry.io/NNNNNNN
ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# Ad unit IDs — required by the release build scripts. Without them the build
# falls back to Google TEST units: zero revenue and an AdMob policy risk.
ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
PRIVACY_POLICY_URL=https://your-org.github.io/privacy
TERMS_OF_USE_URL=https://your-org.github.io/terms
# USDA FoodData Central — free key: https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=Rlz1e8ZtbcRh1GWM1BhUuEnzmdeEOpRNdPnzXRVy
